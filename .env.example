# Anthropic API key used by styre (headless) and the reviewer's model calls.
ANTHROPIC_API_KEY=

# Linear API key for seeding/cleaning up throwaway tickets in the dedicated
# bench Linear project. Must NOT be the operator's ambient key used elsewhere.
LINEAR_API_KEY=

# GitHub token used by the orchestrator's own tooling (e.g. gh/Octokit calls
# unrelated to the throwaway seeded repos below).
GITHUB_TOKEN=

# GitHub PAT scoped ONLY to the throwaway bench org (BENCH_CONFIG.benchGithubOrg).
# Used to seed/clean up per-instance repos. Keep scope minimal (blast-radius).
BENCH_GH_TOKEN=
